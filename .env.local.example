# Supabase（ローカル: npx supabase status の値 / 本番: プロジェクトの値）
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase status の ANON_KEY>"
SUPABASE_SERVICE_ROLE_KEY="<supabase status の SERVICE_ROLE_KEY>"

# アプリケーション
NEXT_PUBLIC_APP_URL="http://localhost:3010"

# Cron（Vercel Cron から Bearer 認証で叩く）
CRON_SECRET="local-dev-secret"

# Stripe（課金。第2弾）— Stripe ダッシュボードの値を入れる
# テスト環境では sk_test_... / pk_test_... を使う
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook の署名シークレット（stripe listen または ダッシュボードの Webhook 設定で取得）
STRIPE_WEBHOOK_SECRET="whsec_..."
# 月額・年額プランの「価格 ID」（商品ではなく価格の ID。price_... 形式）
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_YEARLY="price_..."
